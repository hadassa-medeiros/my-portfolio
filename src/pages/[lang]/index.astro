---
import Translator from "../../lib/translator";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { Slug, Languages } from "../../lib/routes";
import { slugMap, reverseSlugMap } from "../../lib/routes";

const { lang, slug } = Astro.params as { lang: Languages; slug: Slug };
const title = "Hadassa Medeiros";
const translator = new Translator(lang);
const otherLang = lang === "en" ? "es" : "en";
const page = reverseSlugMap[slug];
const otherSlug = "";

export function getStaticPaths() {
  return [
    { params: { lang: "ca", slug: "home" } },
    { params: { lang: "en", slug: "home" } },
    { params: { lang: "es", slug: "home" } },
  ];
}
---

<BaseLayout
  title={title}
  lang={lang}
  otherLang={otherLang}
  slug={slug}
  otherSlug={otherSlug}
>
  <div class="grid-container">
    <!-- <p class="description">Hadassa Medeiros</p> -->
    <div class="icons">
      <a
        class="repo-link"
        href="https://github.com/hadassa-medeiros"
        target="_blank"
      >
        GitHub
      </a>
    </div>
    <div class="bg-layer"></div>
  </div>

  <style lang="scss">
    .bg-layer {
      position: fixed;
      inset: 0;
      z-index: -1;
      opacity: 0.04;
      pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='200' height='200' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 200px;
    }

    .grid-container {
      width: 100%;
      flex: 1 1 auto;
      min-height: 100%;
      padding: 3em;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto 1fr;
      grid-template-areas:
        ".           .           ."
        ".           .           description"
        "icons       icons           .";
      row-gap: 1em;
      justify-items: start;
      text-align: left;
    }

    .title {
      grid-area: title;
      @media (max-width: 768px) {
        font-size: 2em;
      }
    }

    .info {
      grid-area: info;
    }

    .description {
      grid-area: description;
      max-width: 500px;
    }
    .icons {
      grid-area: icons;
      display: flex;
      align-items: center;
      gap: 0.75em;
    }

    .repo-link {
      font-family: "Lora", serif;
      &:hover {
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    }
  </style>
</BaseLayout>

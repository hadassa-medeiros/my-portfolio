---
import Translator from "../lib/translator";
import { languages, slugMap, reverseSlugMap } from "../lib/routes";
import type { Languages, Slug } from "../lib/routes";

const { lang, slug } = Astro.props as { lang: Languages; slug?: Slug };
const translator = new Translator(lang);

const page = slug ? reverseSlugMap[slug] : undefined;
const langHref = (target: Languages) => {
  const localizedSlug = page ? slugMap[target][page] : "";
  return localizedSlug ? `/${target}/${localizedSlug}` : `/${target}`;
};
---

<header>
  <nav>
    <ul>
      <li>
        <a class="nav-link" href={`/${lang}`}>
          {translator.t("ABOUT")}
        </a>
      </li>
      <li class="lang-switcher">
        {
          languages.map((target, i) => (
            <Fragment>
              {i > 0 && <span class="sep" aria-hidden="true"> | </span>}
              <a
                class="nav-link"
                href={langHref(target)}
                aria-current={target === lang ? "page" : undefined}
              >
                {target}
              </a>
            </Fragment>
          ))
        }
      </li>
      <!-- <li>
        <a class="nav-link" href={`/${lang}/projects`}>
          {translator.t("PROJECTS")}
        </a>
      </li> -->
    </ul>
  </nav>
</header>

<style lang="scss">
  .nav-link {
    font-family: "Lora", serif;
    letter-spacing: 0.02em;
  }
  .nav-link:hover {
    opacity: 0.7;
  }
  .lang-switcher .nav-link[aria-current="page"] {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .sep {
    opacity: 0.45;
  }
</style>
